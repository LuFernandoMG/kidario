KIDARIO_ENV=development
KIDARIO_API_V1_PREFIX=/api/v1
KIDARIO_CORS_ORIGINS=http://localhost:5173
KIDARIO_PUBLIC_SITE_URL=https://kidario.app

# Supabase settings
KIDARIO_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
KIDARIO_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Optional but recommended for compensation/rollback in auth signup flow
KIDARIO_SUPABASE_SERVICE_ROLE_KEY=
KIDARIO_SUPABASE_JWT_AUDIENCE=authenticated
KIDARIO_SUPABASE_JWT_ISSUER=
# Optional: set this if your Supabase project signs access tokens with HS256
KIDARIO_SUPABASE_JWT_SECRET=
# Optional CA bundle path for Supabase JWKS HTTPS validation (defaults to certifi)
KIDARIO_SUPABASE_JWKS_CA_BUNDLE=
# Profile photo storage
KIDARIO_PROFILE_PHOTOS_BUCKET=teacher-profile-photos
KIDARIO_PROFILE_PHOTO_MAX_UPLOAD_BYTES=5242880
KIDARIO_PROFILE_PHOTO_SIGNED_URL_TTL_SECONDS=3600
KIDARIO_PROFILE_PHOTO_TARGET_SIZE_PIXELS=512
KIDARIO_PROFILE_PHOTO_JPEG_QUALITY=82
# Optional S3-compatible storage (preferred for server-side uploads)
KIDARIO_STORAGE_S3_ENDPOINT_URL=
KIDARIO_STORAGE_S3_REGION=us-east-1
KIDARIO_STORAGE_S3_ACCESS_KEY_ID=
KIDARIO_STORAGE_S3_SECRET_ACCESS_KEY=

# Teacher activity planner (OpenAI)
KIDARIO_TEACHER_ACTIVITY_LLM_ENABLED=true
KIDARIO_TEACHER_ACTIVITY_LLM_API_KEY=
KIDARIO_TEACHER_ACTIVITY_LLM_MODEL=gpt-4o-mini
KIDARIO_TEACHER_ACTIVITY_LLM_BASE_URL=https://api.openai.com/v1
KIDARIO_TEACHER_ACTIVITY_LLM_TIMEOUT_SECONDS=8.0
# Optional CA bundle path for OpenAI HTTPS validation (defaults to certifi)
KIDARIO_TEACHER_ACTIVITY_LLM_CA_BUNDLE=

# Address geocoding (server-side; no frontend latitude/longitude fields)
KIDARIO_GOOGLE_GEOCODING_API_KEY=
KIDARIO_GOOGLE_GEOCODING_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json
KIDARIO_GOOGLE_GEOCODING_TIMEOUT_SECONDS=5.0
# Optional CA bundle path for Google Geocoding HTTPS validation (defaults to certifi)
KIDARIO_GOOGLE_GEOCODING_CA_BUNDLE=
KIDARIO_VIACEP_BASE_URL=https://viacep.com.br/ws
KIDARIO_VIACEP_TIMEOUT_SECONDS=4.0
# Optional CA bundle path for ViaCEP HTTPS validation (defaults to certifi)
KIDARIO_VIACEP_CA_BUNDLE=

# Signup anti-spam protection
KIDARIO_TRUST_PROXY_HEADERS=true
KIDARIO_SIGNUP_RATE_LIMIT_WINDOW_SECONDS=300
KIDARIO_SIGNUP_RATE_LIMIT_MAX_ATTEMPTS_PER_IP=20
KIDARIO_SIGNUP_RATE_LIMIT_MAX_ATTEMPTS_PER_EMAIL=8
KIDARIO_SIGNUP_CAPTCHA_REQUIRED=false
KIDARIO_SIGNUP_CAPTCHA_PROVIDER=turnstile
KIDARIO_SIGNUP_CAPTCHA_SECRET_KEY=
# Optional override (defaults to provider endpoint)
KIDARIO_SIGNUP_CAPTCHA_VERIFY_URL=
KIDARIO_SIGNUP_CAPTCHA_TIMEOUT_SECONDS=8.0
KIDARIO_SIGNUP_CAPTCHA_RECAPTCHA_MIN_SCORE=0.5

# Postgres URL from Supabase (pooler or direct)
KIDARIO_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/postgres

# Comma-separated admin emails for admin endpoints
KIDARIO_ADMIN_EMAILS=admin@kidario.com

# Pagar.me PSP (test/sandbox)
# Use the test secret key while validating recipients, orders, charges, and split.
KIDARIO_PAGARME_SECRET_KEY=
KIDARIO_PAGARME_BASE_URL=https://api.pagar.me/core/v5
KIDARIO_PAGARME_WEBHOOK_SECRET=
KIDARIO_PAGARME_PLATFORM_RECIPIENT_ID=
KIDARIO_PAGARME_TIMEOUT_SECONDS=15
KIDARIO_PAGARME_CA_BUNDLE=
KIDARIO_PLATFORM_FEE_PERCENT=20
