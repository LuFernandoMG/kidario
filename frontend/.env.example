# Supabase project URL, e.g. https://abc123xyz.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# Supabase anon/public key from Project Settings -> API
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# FastAPI backend base URL with API prefix
VITE_BACKEND_API_URL=http://localhost:8000/api/v1
# Supabase public bucket for teacher profile photos
VITE_SUPABASE_PROFILE_PHOTOS_BUCKET=teacher-profile-photos

# Signup anti-spam (Cloudflare Turnstile)
VITE_SIGNUP_CAPTCHA_ENABLED=false
VITE_TURNSTILE_SITE_KEY=
